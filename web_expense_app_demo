## 3. app.js (核心逻辑框架)
```javascript
// 数据管理类
class ExpenseApp {
    constructor() {
        this.transactions = this.loadTransactions();
        this.categories = [
            { id: 1, name: '餐饮', color: '#FF6B6B', icon: '🍔' },
            { id: 2, name: '交通', color: '#4ECDC4', icon: '🚗' },
            { id: 3, name: '购物', color: '#45B7D1', icon: '🛍️' },
            { id: 4, name: '娱乐', color: '#96CEB4', icon: '🎮' },
            { id: 5, name: '医疗', color: '#FFEAA7', icon: '🏥' },
            { id: 6, name: '教育', color: '#DDA0DD', icon: '📚' },
            { id: 7, name: '其他', color: '#778899', icon: '📦' }
        ];
        this.init();
    }

    // 从LocalStorage加载数据
    loadTransactions() {
        const data = localStorage.getItem('expense-transactions');
        return data ? JSON.parse(data) : [];
    }

    // 保存数据到LocalStorage
    saveTransactions() {
        localStorage.setItem('expense-transactions', JSON.stringify(this.transactions));
    }

    // 初始化应用
    init() {
        this.setupEventListeners();
        this.renderTransactions();
        this.updateBalance();
        this.renderBubbleChart();
    }

    // 设置事件监听器
    setupEventListeners() {
        const form = document.getElementById('transaction-form');
        if (form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                this.addTransaction();
            });
        }

        // 底部导航切换
        document.querySelectorAll('.nav-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                this.switchPage(e.target.dataset.page);
            });
        });
    }

    // 添加交易记录
    addTransaction() {
        const amount = parseFloat(document.getElementById('amount').value);
        const type = document.getElementById('type').value;
        const category = document.getElementById('category').value;
        const note = document.getElementById('note').value;

        if (!amount || amount <= 0) {
            alert('请输入有效的金额');
            return;
        }

        const transaction = {
            id: Date.now(),
            amount,
            type,
            category,
            note: note || '',
            date: new Date().toISOString().split('T')[0]
        };

        this.transactions.unshift(transaction);
        this.saveTransactions();
        this.renderTransactions();
        this.updateBalance();
        this.renderBubbleChart();
        
        // 清空表单
        document.getElementById('transaction-form').reset();
        
        // 显示成功提示
        this.showToast('记录添加成功!');
    }

    // 显示交易列表
    renderTransactions() {
        const container = document.getElementById('transactions-container');
        if (!container) return;

        if (this.transactions.length === 0) {
            container.innerHTML = '<p class="empty-message">暂无记录，开始记账吧！</p>';
            return;
        }

        container.innerHTML = this.transactions.slice(0, 10).map(transaction => `
            <div class="transaction-item">
                <div class="transaction-info">
                    <div class="transaction-category">
                        ${this.getCategoryIcon(transaction.category)} ${transaction.category}
                    </div>
                    <div class="transaction-note">${transaction.note || '无备注'}</div>
                    <div class="transaction-date">${transaction.date}</div>
                </div>
                <div class="transaction-amount ${transaction.type}">
                    ${transaction.type === 'expense' ? '-' : '+'}¥${transaction.amount.toFixed(2)}
                </div>
            </div>
        `).join('');
    }

    // 获取分类图标
    getCategoryIcon(categoryName) {
        const category = this.categories.find(c => c.name === categoryName);
        return category ? category.icon : '📦';
    }

    // 更新余额显示
    updateBalance() {
        const balanceElement = document.getElementById('current-balance');
        if (!balanceElement) return;

        const totalIncome = this.transactions
            .filter(t => t.type === 'income')
            .reduce((sum, t) => sum + t.amount, 0);
        
        const totalExpense = this.transactions
            .filter(t => t.type === 'expense')
            .reduce((sum, t) => sum + t.amount, 0);
        
        const balance = totalIncome - totalExpense;
        balanceElement.textContent = `¥${balance.toFixed(2)}`;
        
        // 更新月度统计
        this.updateMonthlySummary();
    }

    // 更新月度统计
    updateMonthlySummary() {
        const currentMonth = new Date().toISOString().slice(0, 7); // YYYY-MM格式
        
        const monthExpense = this.transactions
            .filter(t => t.type === 'expense' && t.date.startsWith(currentMonth))
            .reduce((sum, t) => sum + t.amount, 0);
        
        const monthIncome = this.transactions
            .filter(t => t.type === 'income' && t.date.startsWith(currentMonth))
            .reduce((sum, t) => sum + t.amount, 0);
        
        const expenseElement = document.getElementById('month-expense');
        const incomeElement = document.getElementById('month-income');
        
        if (expenseElement) expenseElement.textContent = `¥${monthExpense.toFixed(2)}`;
        if (incomeElement) incomeElement.textContent = `¥${monthIncome.toFixed(2)}`;
    }

    // 渲染气泡图 (色块大小可视化)
    renderBubbleChart() {
        const container = document.getElementById('bubble-chart');
        if (!container) return;

        // 按分类统计支出
        const categoryExpenses = {};
        this.transactions
            .filter(t => t.type === 'expense')
            .forEach(t => {
                categoryExpenses[t.category] = (categoryExpenses[t.category] || 0) + t.amount;
            });

        // 清空容器
        container.innerHTML = '';

        // 创建气泡
        Object.entries(categoryExpenses).forEach(([category, amount]) => {
            const categoryData = this.categories.find(c => c.name === category);
            const color = categoryData ? categoryData.color : '#778899';
            const icon = categoryData ? categoryData.icon : '📦';
            
            // 气泡大小基于金额 (最小30px，最大120px)
            const size = Math.min(120, Math.max(30, Math.sqrt(amount) * 3));
            
            const bubble = document.createElement('div');
            bubble.className = 'bubble-item';
            bubble.style.cssText = `
                width: ${size}px;
                height: ${size}px;
                background-color: ${color};
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-weight: bold;
                margin: 5px;
                position: relative;
                box-shadow: 0 3px 10px rgba(0,0,0,0.2);
            `;
            
            bubble.innerHTML = `
                <div style="font-size: ${size/3}px;">${icon}</div>
                <div style="position: absolute; bottom: -25px; font-size: 12px; color: #666; white-space: nowrap;">
                    ${category}<br>¥${amount.toFixed(0)}
                </div>
            `;
            
            container.appendChild(bubble);
        });
    }

    // 切换页面
    switchPage(page) {
        // 更新导航按钮状态
        document.querySelectorAll('.nav-btn').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.page === page);
        });

        // 这里可以添加页面切换逻辑
        console.log('切换到页面:', page);
    }

    // 显示提示消息
    showToast(message) {
        const toast = document.createElement('div');
        toast.textContent = message;
        toast.style.cssText = `
            position: fixed;
            bottom: 80px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.8);
            color: white;
            padding: 12px 24px;
            border-radius: 25px;
            z-index: 1000;
            animation: fadeInOut 2s ease-in-out;
        `;
        
        document.body.appendChild(toast);
        
        setTimeout(() => {
            document.body.removeChild(toast);
        }, 2000);
    }
}

// 初始化应用
document.addEventListener('DOMContentLoaded', () => {
    window.app = new ExpenseApp();
});
```

