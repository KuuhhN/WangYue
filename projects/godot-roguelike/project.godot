[application]
config/name="Food Roguelike"
config/description="A roguelike game with food-themed characters"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.0")

[autoload]
GameManager="*res://autoload/GameManager.gd"
SpriteGen="*res://autoload/SpriteGen.gd"
EventBus="*res://autoload/EventBus.gd"

[rendering]
renderer/rendering_method="forward_plus"

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/initial_window_mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[input]
move_left={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"keycode":65,"physical_keycode":0,"key_label":0,"unicode":0,"modifier_keycode":0,"ctrl_pressed":false,"shift_pressed":false,"alt_pressed":false,"meta_pressed":false,"pressed":false,"echo":false,"script":null)
]
}
move_right={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"keycode":68,"physical_keycode":0,"key_label":0,"unicode":0,"modifier_keycode":0,"ctrl_pressed":false,"shift_pressed":false,"alt_pressed":false,"meta_pressed":false,"pressed":false,"echo":false,"script":null)
]
}
move_up={
